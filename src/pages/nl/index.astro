        "areaServed": [
          { "@type": "Country", "name": "België" },
          { "@type": "Country", "name": "Frankrijk" },
          { "@type": "Country", "name": "Luxemburg" },
          { "@type": "Country", "name": "Nederland" },
          { "@type": "City", "name": "Brussel" },
          { "@type": "City", "name": "Luik" },
          { "@type": "City", "name": "Antwerpen" },
          { "@type": "City", "name": "Namen" },
          { "@type": "City", "name": "Gent" },
          { "@type": "City", "name": "Parijs" },
          { "@type": "City", "name": "Luxemburg-Stad" }
        ],
        "availableLanguage": [
          { "@type": "Language", "name": "French", "alternateName": "fr" },
          { "@type": "Language", "name": "Dutch", "alternateName": "nl" },
          { "@type": "Language", "name": "English", "alternateName": "en" }
        ],
        "sameAs": [
          "https://www.linkedin.com/company/codelli-engineering/",
          "https://www.instagram.com/codelli.tech/"
        ],
        "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
        "priceRange": "$$-$$$",
        "vatID": "BE1006208714",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Codelli Diensten",
          "itemListElement": [
            { "@type": "OfferCatalog", "name": "Website — vitrines & landing pages" },
            { "@type": "OfferCatalog", "name": "AI & Automatisering" },
            { "@type": "OfferCatalog", "name": "Applicaties & SaaS" }
          ]
        }
      },
      {
        "@type": "Person",
        "@id": "https://codelli.tech/#cem-tekelli",
        "name": "Cem Tekelli",
        "givenName": "Cem",
        "familyName": "Tekelli",
        "jobTitle": "Oprichter & Lead Developer",
        "description": "Cem Tekelli is de oprichter van Codelli, een AI digitaal studio in Brussel. 5 jaar enterprise-ervaring bij IBM, DXC Technology en RTBF voordat hij Codelli oprichtte. Full-stack expert gespecialiseerd in webontwikkeling, mobiele apps en AI-integratie voor kmo's en startups.",
        "worksFor": { "@id": "https://codelli.tech/#organization" },
        "url": "https://codelli.tech/nl/cem-tekelli",
        "email": "info@codelli.tech",
        "knowsAbout": [
          "Webontwikkeling","Mobiele app-ontwikkeling","AI-integratie","FastAPI","Vue.js","React","Next.js",
          "Node.js","Python","n8n Automatisering","Digitale transformatie","UX/UI Design","SaaS-ontwikkeling",
          "MVP-ontwikkeling","PostgreSQL","React Native","LLM-integratie"
        ],
        "address": { "@type": "PostalAddress", "addressLocality": "Brussel", "addressCountry": "BE" },
        "sameAs": ["https://www.linkedin.com/in/cemtekelli/", "https://www.linkedin.com/company/codelli-engineering/"]
      },
      {
        "@type": "Service",
        "@id": "https://codelli.tech/#service-showcase",
        "serviceType": "Website Design",
        "name": "Website — vitrines & landing pages",
        "description": "Presentatiewebsites en landing pages op maat voor kmo's en startups. Design, content en performance geoptimaliseerd voor conversie. Online in 2 tot 4 weken.",
        "provider": { "@id": "https://codelli.tech/#organization" },
        "offers": { "@type": "Offer", "price": "2900", "priceCurrency": "EUR", "description": "Vanaf €2.900" },
        "areaServed": [{"@type": "Country", "name": "België"}, {"@type": "Country", "name": "Frankrijk"}, {"@type": "Country", "name": "Luxemburg"}, {"@type": "Country", "name": "Nederland"}],
        "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "https://codelli.tech/nl/#contact" }
      },
      {
        "@type": "Service",
        "@id": "https://codelli.tech/#service-ai",
        "serviceType": "AI Integration",
        "name": "AI & Automatisering",
        "description": "Codelli bouwt AI-chatbots, intelligente agenten en automatiseringssystemen (n8n) op maat voor kmo's en startups. Van use-case-audit tot productie-implementatie.",
        "provider": { "@id": "https://codelli.tech/#organization" },
        "offers": { "@type": "Offer", "price": "3500", "priceCurrency": "EUR", "description": "Audit + PoC vanaf €3.500; project in productie €12.000 tot €30.000" },
        "areaServed": [{"@type": "Country", "name": "België"}, {"@type": "Country", "name": "Frankrijk"}, {"@type": "Country", "name": "Luxemburg"}, {"@type": "Country", "name": "Nederland"}],
        "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "https://codelli.tech/nl/#contact" }
      },
      {
        "@type": "Service",
        "@id": "https://codelli.tech/#service-web",
        "serviceType": "Web Development",
        "name": "Applicaties & SaaS",
        "description": "Web- en mobiele applicaties, SaaS-platformen op maat (web en mobiel inbegrepen). Stack React, Vue.js, Next.js, FastAPI, Node.js, React Native. Van MVP tot productieklaar product.",
        "provider": { "@id": "https://codelli.tech/#organization" },
        "offers": { "@type": "Offer", "price": "12000", "priceCurrency": "EUR", "description": "MVP vanaf €12.000; maatwerk €12.000 tot €50.000" },
        "areaServed": [{"@type": "Country", "name": "België"}, {"@type": "Country", "name": "Frankrijk"}, {"@type": "Country", "name": "Luxemburg"}, {"@type": "Country", "name": "Nederland"}],
        "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "https://codelli.tech/nl/#contact" }
      },
      {
        "@type": "HowTo",
        "@id": "https://codelli.tech/nl/#process",
        "name": "Hoe Codelli uw digitaal project levert",
        "description": "Het ontwikkelingsproces van Codelli in 4 stappen — van ontdekking tot lancering. Reken op 6 tot 8 weken voor een standaardproject.",
        "totalTime": "PT6W",
        "step": [
          { "@type": "HowToStep", "position": 1, "name": "Ontdekking (1–2 weken)", "text": "We leren uw bedrijf kennen, definiëren de scope, het budget en de planning. Een gratis ontdekkingsgesprek van 30 minuten om te beginnen.", "url": "https://codelli.tech/nl/#process" },
          { "@type": "HowToStep", "position": 2, "name": "Design (2–3 weken)", "text": "U valideert echte high-fidelity mockups voordat er één regel code wordt geschreven. Geen visuele verrassingen bij de lancering.", "url": "https://codelli.tech/nl/#process" },
          { "@type": "HowToStep", "position": 3, "name": "Ontwikkeling (3–6 weken)", "text": "Full-stack ontwikkeling versneld door AI. 2–3x sneller geleverd dan een traditioneel bureau. Tests, QA en integraties inbegrepen.", "url": "https://codelli.tech/nl/#process" },
          { "@type": "HowToStep", "position": 4, "name": "Lancering & Groei (doorlopend)", "text": "Implementatie, productirelease en monitoring na de lancering. Codelli blijft uw langetermijn technische partner.", "url": "https://codelli.tech/nl/#process" }
        ]
      },
      {
        "@type": "FAQPage",
        "@id": "https://codelli.tech/nl/#faq",
        "mainEntity": [
          { "@type": "Question", "name": "Wat is Codelli?", "acceptedAnswer": { "@type": "Answer", "text": "Codelli is een AI digitaal studio opgericht door Cem Tekelli, gevestigd in Brussel. Codelli ontwerpt, ontwikkelt en integreert kunstmatige intelligentie voor kmo's en startups: websites, mobiele applicaties, chatbots, automatisering en intelligente agenten. Van concept tot lancering in 6 tot 8 weken voor een standaardproject." } },
          { "@type": "Question", "name": "Wie is Cem Tekelli?", "acceptedAnswer": { "@type": "Answer", "text": "Cem Tekelli is de oprichter en lead developer van Codelli, een digitaal studio gevestigd in Brussel, België. Expert in full-stack webontwikkeling (React, Vue.js, FastAPI, Node.js), mobiele ontwikkeling (React Native) en AI-integratie voor Belgische en Europese kmo's en startups." } },
          { "@type": "Question", "name": "Welke diensten biedt Codelli aan?", "acceptedAnswer": { "@type": "Answer", "text": "Codelli biedt drie diensten aan: (1) Website — vitrines & landing pages, vanaf €2.900; (2) AI & Automatisering — chatbots, AI-agenten, n8n workflows, audit/PoC vanaf €3.500 (project in productie €12.000 tot €30.000); (3) Applicaties & SaaS — web-apps, mobiel en platformen op maat, MVP vanaf €12.000. Design is inbegrepen in elk project." } },
          { "@type": "Question", "name": "Hoeveel kost een website?", "acceptedAnswer": { "@type": "Answer", "text": "De prijs hangt af van de complexiteit. Een website start vanaf €2.900. Een maatwerk web- of mobiele applicatie gaat van €12.000 tot €50.000. Alle projecten tegen vaste prijs — neem contact op voor een gratis gepersonaliseerde offerte." } },
          { "@type": "Question", "name": "Hoe lang duurt een project?", "acceptedAnswer": { "@type": "Answer", "text": "De doorlooptijd hangt af van het project: een website duurt 2 tot 4 weken, een maatwerkproject (app, SaaS, AI-integratie) 6 tot 12 weken afhankelijk van de scope. We stellen een nauwkeurige planning en vaste prijs vast bij de start van het project." } },
          { "@type": "Question", "name": "Kunnen Belgische kmo's subsidies krijgen voor een AI-project?", "acceptedAnswer": { "@type": "Answer", "text": "Er bestaan verschillende regionale regelingen (bedragen en beschikbaarheid variëren — per geval te controleren). In Wallonië dekt de cheque \"Digitale maturiteit\" (Chèques-entreprises) 50% van strategisch advies/diagnose. In Vlaanderen subsidieert de KMO-portefeuille opleidingen (20-30%) en cybersecurity-advies (35-45%). In Brussel is de Innoviris Start AI-voucher (tot 75% van de AI-studie) opgeschort in 2026. Codelli helpt u de regelingen te identificeren die u echt kunt gebruiken en het dossier op te stellen." } },
          { "@type": "Question", "name": "Wat maakt Codelli anders dan een traditioneel webbureau?", "acceptedAnswer": { "@type": "Answer", "text": "Codelli combineert design, ontwikkeling en AI onder één dak, zonder uitbesteding. Dankzij AI in het ontwikkelingsproces leveren we 2-3x sneller dan een traditioneel bureau. Alle projecten worden geleverd tegen een vaste prijs en binnen de aangekondigde deadline." } },
          { "@type": "Question", "name": "Hoe integreer ik ChatGPT of een LLM in mijn bedrijf?", "acceptedAnswer": { "@type": "Answer", "text": "Codelli analyseert uw bestaand systeem, identificeert waardevolle use cases en bouwt de integratie via OpenAI, Anthropic API's of open-source modellen (Mistral, LLaMA). Audit + PoC vanaf €3.500, project in productie €12.000 tot €30.000. Een werkende proof of concept wordt geleverd voor enige langetermijnverplichting." } },
          { "@type": "Question", "name": "Werkt Codelli ook met bedrijven in Nederland, Frankrijk en Luxemburg?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Codelli bedient B2B-kmo's en startups in België, Nederland, Frankrijk en Luxemburg. Alle opdrachten kunnen volledig op afstand worden uitgevoerd. We communiceren in het Frans, Nederlands en Engels en begrijpen de lokale regelgeving van elke markt." } },
          { "@type": "Question", "name": "Wat is de ROI van AI-integratie voor een kmo?", "acceptedAnswer": { "@type": "Answer", "text": "Het voordeel hangt af van de use case: een repetitieve taak automatiseren of een deel van uw supportvragen afleiden maakt meetbare tijd vrij voor uw team. In plaats van een algemeen cijfer schatten we uw concrete ROI — volumes, kosten, doorlooptijden — tijdens het gratis kennismakingsgesprek." } }
        ]
      },
      {
        "@type": "Review",
        "@id": "https://codelli.tech/#review-1",
        "reviewBody": "Codelli heeft onze online aanwezigheid volledig getransformeerd. In een paar weken hadden we een site die de identiteit van Baba Events echt weerspiegelt en echte leads genereert. Het resultaat overtrof onze verwachtingen.",
        "author": {"@type": "Person", "name": "Rifat Balaj"},
        "reviewRating": {"@type": "Rating", "ratingValue": "5", "bestRating": "5"},
        "itemReviewed": {"@id": "https://codelli.tech/#organization"}
      },
      {
        "@type": "Review",
        "@id": "https://codelli.tech/#review-2",
        "reviewBody": "Cem begrijpt de behoeften van ondernemers. Hij leverde geen applicatie — hij leverde een oplossing die mijn team elke dag tijd bespaart. Professioneel, responsief en echt betrokken bij het project.",
        "author": {"@type": "Person", "name": "Obaida Isarti"},
        "reviewRating": {"@type": "Rating", "ratingValue": "5", "bestRating": "5"},
        "itemReviewed": {"@id": "https://codelli.tech/#organization"}
      },
      {
        "@type": "Review",
        "@id": "https://codelli.tech/#review-3",
        "reviewBody": "We zochten een betrouwbare technische partner om een deel van onze activiteiten bij Nautilus te digitaliseren. Codelli leverde op tijd, binnen het budget, en het product werkt precies zoals gepland. Ik beveel het zonder aarzeling aan.",
        "author": {"@type": "Person", "name": "Fuat Yuksel"},
        "reviewRating": {"@type": "Rating", "ratingValue": "5", "bestRating": "5"},
        "itemReviewed": {"@id": "https://codelli.tech/#organization"}
      },
      {
        "@type": "WebSite",
        "@id": "https://codelli.tech/#website",
        "url": "https://codelli.tech",
        "name": "Codelli - AI Digitaal Studio Brussel",
        "publisher": { "@id": "https://codelli.tech/#organization" },
        "inLanguage": ["fr-BE", "nl-BE", "en"]
      }
    ]
  }
  </script>

  <Hero lang={lang} />
  <Services lang={lang} />
  <Portfolio lang={lang} />
  <About lang={lang} />
  <Testimonials lang={lang} />
  <Process lang={lang} />
  <SubsidyBanner lang={lang} />
  <TechStack lang={lang} />
  <FAQ lang={lang} />
  <FabButtons lang={lang} />
