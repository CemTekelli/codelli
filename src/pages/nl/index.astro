---
import PageLayout from '../../layouts/PageLayout.astro';
import FabButtons from '../../components/FabButtons.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Portfolio from '../../components/sections/Portfolio.astro';
import About from '../../components/sections/About.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Process from '../../components/sections/Process.astro';
import SubsidyBanner from '../../components/sections/SubsidyBanner.astro';
import TechStack from '../../components/sections/TechStack.astro';
import FAQ from '../../components/sections/FAQ.astro';
import LatestArticles from '../../components/sections/LatestArticles.astro';
import Contact from '../../components/sections/Contact.astro';

const lang = 'nl';
const canonical = '/nl/';
---

<PageLayout lang={lang} canonical={canonical}>
  <script type="application/ld+json" slot="schema">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["Organization", "ProfessionalService"],
        "@id": "https://codelli.tech/#organization",
        "name": "Codelli",
        "legalName": "Codelli",
        "description": "Codelli is een AI digitaal studio opgericht door Cem Tekelli in Brussel. Gespecialiseerd in AI-integratie, web- en mobiele ontwikkeling en UX/UI design voor kmo's en startups.",
        "image": "https://codelli.tech/codelli-logo.svg",
        "logo": { "@type": "ImageObject", "url": "https://codelli.tech/codelli-logo.svg", "width": 512, "height": 512 },
        "url": "https://codelli.tech",
        "telephone": "+32472628430",
        "email": "info@codelli.tech",
        "founder": { "@id": "https://codelli.tech/#cem-tekelli" },
        "employee": { "@id": "https://codelli.tech/#cem-tekelli" },
        "knowsAbout": [
          "Webontwikkeling","Mobiele app-ontwikkeling","AI-integratie",
          "AI-automatisering","Chatbots","AI-agenten","FastAPI","Vue.js","React","Next.js","Node.js","Python",
          "n8n","SaaS-ontwikkeling","MVP-ontwikkeling","UX/UI Design","Digitale transformatie",
          "Startupontwikkeling","PostgreSQL","React Native","LLM-integratie"
