---
import PageLayout from '../layouts/PageLayout.astro';
import { t, localePath } from '../i18n/utils';

const lang = 'fr';
const canonical = '/privacy';
---

<PageLayout
  lang={lang}
  title={t(lang, 'privacy.meta.title')}
  description={t(lang, 'privacy.meta.description')}
  canonical={canonical}
  bodyClass=""
  navLangUrls={{ fr: '/privacy', nl: '/nl/privacy', en: '/en/privacy' }}
  navBackHref={localePath(lang, '/')}
  navBackLabel={t(lang, 'blog.nav.back')}
>
  <div class="priv-page">

    <!-- Content -->
    <main class="priv-content">
      <h1 class="priv-title">{t(lang, 'privacy.page.title')}</h1>
      <p class="priv-updated">{t(lang, 'privacy.page.updated')}</p>

      <!-- Mentions légales -->
      <section class="priv-section" id="mentions">
        <h2 class="priv-section-title">{t(lang, 'privacy.legal.title')}</h2>

        <div class="priv-info-box">
          <p><strong>{t(lang, 'privacy.legal.label.company')}</strong> Codelli Engineering</p>
          <p><strong>{t(lang, 'privacy.legal.label.form')}</strong> {t(lang, 'privacy.legal.value.form')}</p>
          <p><strong>{t(lang, 'privacy.legal.label.vat')}</strong> 1006.208.714</p>
          <p><strong>{t(lang, 'privacy.legal.label.address')}</strong> {t(lang, 'privacy.legal.value.address')}</p>
          <p><strong>{t(lang, 'privacy.legal.label.email')}</strong> <a href="mailto:hello@codelli.tech">hello@codelli.tech</a></p>
          <p><strong>{t(lang, 'privacy.legal.label.phone')}</strong> +32 472 62 84 30</p>
          <p><strong>{t(lang, 'privacy.legal.label.publisher')}</strong> {t(lang, 'privacy.legal.value.publisher')}</p>
        </div>

        <p set:html={t(lang, 'privacy.legal.desc')} />
      </section>

      <!-- Politique de confidentialité -->
      <section class="priv-section" id="confidentialite">
        <h2 class="priv-section-title">{t(lang, 'privacy.gdpr.title')}</h2>

        <p>{t(lang, 'privacy.gdpr.intro')}</p>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.gdpr.dataTitle')}</h3>
        <p>{t(lang, 'privacy.gdpr.dataIntro')}</p>
        <ul>
          <li>{t(lang, 'privacy.gdpr.dataItems.1')}</li>
          <li>{t(lang, 'privacy.gdpr.dataItems.2')}</li>
          <li>{t(lang, 'privacy.gdpr.dataItems.3')}</li>
          <li>{t(lang, 'privacy.gdpr.dataItems.4')}</li>
          <li>{t(lang, 'privacy.gdpr.dataItems.5')}</li>
        </ul>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.gdpr.purposesTitle')}</h3>
        <ul>
          <li set:html={t(lang, 'privacy.gdpr.purposes.1')} />
          <li set:html={t(lang, 'privacy.gdpr.purposes.2')} />
          <li set:html={t(lang, 'privacy.gdpr.purposes.3')} />
        </ul>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.gdpr.retentionTitle')}</h3>
        <p set:html={t(lang, 'privacy.gdpr.retention')} />

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.gdpr.recipientsTitle')}</h3>
        <p>{t(lang, 'privacy.gdpr.recipientsIntro')}</p>
        <ul>
          <li set:html={t(lang, 'privacy.gdpr.recipients.1')} />
          <li set:html={t(lang, 'privacy.gdpr.recipients.2')} />
        </ul>
        <p>{t(lang, 'privacy.gdpr.recipientsNote')}</p>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.gdpr.rightsTitle')}</h3>
        <p>{t(lang, 'privacy.gdpr.rightsIntro')}</p>
        <ul>
          <li set:html={t(lang, 'privacy.gdpr.rights.1')} />
          <li set:html={t(lang, 'privacy.gdpr.rights.2')} />
          <li set:html={t(lang, 'privacy.gdpr.rights.3')} />
          <li set:html={t(lang, 'privacy.gdpr.rights.4')} />
          <li set:html={t(lang, 'privacy.gdpr.rights.5')} />
          <li set:html={t(lang, 'privacy.gdpr.rights.6')} />
        </ul>
        <p set:html={t(lang, 'privacy.gdpr.rightsContact')} />
      </section>

      <!-- Cookies -->
      <section class="priv-section" id="cookies">
        <h2 class="priv-section-title">{t(lang, 'privacy.cookiePolicy.title')}</h2>

        <p>{t(lang, 'privacy.cookiePolicy.intro')}</p>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.cookiePolicy.listTitle')}</h3>
        <div class="priv-table-wrap">
          <table class="priv-cookie-table" aria-label={t(lang, 'privacy.cookiePolicy.tableLabel')}>
            <thead>
              <tr>
                <th>{t(lang, 'privacy.cookiePolicy.thead.name')}</th>
                <th>{t(lang, 'privacy.cookiePolicy.thead.provider')}</th>
                <th>{t(lang, 'privacy.cookiePolicy.thead.purpose')}</th>
                <th>{t(lang, 'privacy.cookiePolicy.thead.duration')}</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>_ga</code>, <code>_ga_*</code></td>
                <td>Google Analytics</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.ga.purpose')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.ga.duration')}</td>
              </tr>
              <tr>
                <td><code>_gtm_*</code></td>
                <td>Google Tag Manager</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.gtm.purpose')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.gtm.duration')}</td>
              </tr>
              <tr>
                <td><code>codelli_cookie_consent</code></td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.consent.provider')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.consent.purpose')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.consent.duration')}</td>
              </tr>
              <tr>
                <td><code>codelli-lang</code></td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.lang.provider')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.lang.purpose')}</td>
                <td>{t(lang, 'privacy.cookiePolicy.rows.lang.duration')}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="priv-section-subtitle">{t(lang, 'privacy.cookiePolicy.prefsTitle')}</h3>
        <p>{t(lang, 'privacy.cookiePolicy.prefsIntro')}</p>
        <ul>
          <li set:html={t(lang, 'privacy.cookiePolicy.browserChrome')} />
          <li set:html={t(lang, 'privacy.cookiePolicy.browserFirefox')} />
          <li set:html={t(lang, 'privacy.cookiePolicy.browserSafari')} />
        </ul>
        <p set:html={t(lang, 'privacy.cookiePolicy.gaOptout')} />
      </section>

      <!-- Limitation de responsabilité -->
      <section class="priv-section">
        <h2 class="priv-section-title">{t(lang, 'privacy.liability.title')}</h2>
        <p>{t(lang, 'privacy.liability.p1')}</p>
        <p>{t(lang, 'privacy.liability.p2')}</p>
      </section>

      <!-- Contact -->
      <section class="priv-section">
        <h2 class="priv-section-title">{t(lang, 'privacy.contact.title')}</h2>
        <div class="priv-info-box">
          <p><strong>Codelli Engineering</strong></p>
          <p>{t(lang, 'privacy.contact.address')}</p>
          <p><a href="mailto:hello@codelli.tech">hello@codelli.tech</a></p>
          <p>+32 472 62 84 30</p>
        </div>
      </section>

    </main>
  </div>
</PageLayout>

<style is:global>
  /* ─── Privacy page ───────────────────────────────────────────── */
  .priv-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 3rem 7rem;
  }

  .priv-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .priv-updated {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
    margin-bottom: 4rem;
  }

  /* Sections */
  .priv-section {
    margin-bottom: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .priv-section:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .priv-section-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .priv-section-subtitle {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .priv-content p {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.85rem;
  }

  .priv-content ul {
    margin: 0.75rem 0 0.85rem 1.25rem;
  }

  .priv-content ul li {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.4rem;
  }

  .priv-content a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .priv-content a:hover { text-decoration: underline; }

  .priv-content strong { color: rgba(255,255,255,0.75); font-weight: 600; }

  .priv-info-box {
    border: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    background: rgba(255,255,255,0.02);
  }

  .priv-info-box p { margin-bottom: 0.4rem; }
  .priv-info-box p:last-child { margin-bottom: 0; }

  /* Table */
  .priv-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1rem 0 1.5rem;
  }

  .priv-cookie-table {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .priv-cookie-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.5);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .priv-cookie-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.5);
    vertical-align: top;
  }

  .priv-cookie-table tr:last-child td { border-bottom: none; }

  .priv-cookie-table code {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.05);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }

  @media (max-width: 768px) {
    .priv-content { padding: 3rem 1.5rem 5rem; }
  }
</style>
