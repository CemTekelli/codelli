---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromUrl, localePath } from '../i18n/utils';

// Astro passe l'URL courante — on détecte la langue depuis le path
const lang = getLangFromUrl(Astro.url);
---

<BaseLayout
  lang={lang}
  title="404 — Page introuvable | Codelli"
  description="Cette page n'existe pas ou a été déplacée."
  canonical="/404"
  bodyClass=""
>
  <div class="not-found-page">
    <div class="not-found-inner">
      <span class="not-found-code">404</span>
      <h1 class="not-found-title">
        {lang === 'fr' ? 'Page introuvable' : lang === 'nl' ? 'Pagina niet gevonden' : 'Page not found'}
      </h1>
      <p class="not-found-desc">
        {lang === 'fr'
          ? 'Cette page n\'existe pas ou a été déplacée.'
          : lang === 'nl'
          ? 'Deze pagina bestaat niet of is verplaatst.'
          : 'This page doesn\'t exist or has been moved.'}
      </p>
      <a href={localePath(lang, '/')} class="not-found-cta">
        {lang === 'fr' ? '← Retour à l\'accueil' : lang === 'nl' ? '← Terug naar home' : '← Back to home'}
      </a>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .not-found-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .not-found-inner {
    text-align: center;
    max-width: 480px;
  }
  .not-found-code {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(255,255,255,0.06);
    margin-bottom: 1.5rem;
  }
  .not-found-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .not-found-desc {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }
  .not-found-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.75rem 2rem;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .not-found-cta:hover {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.35);
  }
</style>
