    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.9rem;
  }

  .ct-tag-group { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .ct-tag {
    font-family: var(--font-display);
    font-size: 0.78rem;
