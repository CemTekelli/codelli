---
import PageLayout from '../../layouts/PageLayout.astro';
import { t, localePath } from '../../i18n/utils';
import { CALENDLY_URL } from '../../config';

const lang = 'en';
const canonical = '/en/cem-tekelli';
---

<PageLayout
  lang={lang}
  title={t(lang, 'person.meta.title')}
  description={t(lang, 'person.meta.description')}
  canonical={canonical}
  bodyClass=""
  navLangUrls={{ fr: '/cem-tekelli', nl: '/nl/cem-tekelli', en: '/en/cem-tekelli' }}
  navBackHref={localePath(lang, '/')}
  navBackLabel={t(lang, 'person.nav.back')}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" slot="schema">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://codelli.tech/cem-tekelli#person",
        "name": "Cem Tekelli",
        "givenName": "Cem",
        "familyName": "Tekelli",
        "jobTitle": "Founder & Lead Developer",
        "description": "Cem Tekelli is the founder of Codelli, an AI digital studio based in Brussels. 5 years of enterprise experience (IBM, DXC Technology, RTBF) before launching Codelli. Full-stack expert specialised in web development, mobile apps and AI integration for SMEs and startups.",
        "url": "https://codelli.tech/en/cem-tekelli",
        "image": "https://codelli.tech/cem-tekelli.jpg",
        "email": "tekelli.cem@outlook.com",
        "worksFor": {
          "@type": "Organization",
          "@id": "https://codelli.tech/#organization",
          "name": "Codelli",
          "url": "https://codelli.tech"
        },
        "knowsAbout": ["Web Development","Mobile App Development","AI Integration","FastAPI","Vue.js","React","Next.js","Node.js","Python","n8n Automation","TypeScript","GraphQL","LLM Integration","RAG","SaaS Development"],
        "knowsLanguage": [
          {"@type": "Language", "name": "French", "alternateName": "fr"},
          {"@type": "Language", "name": "Dutch", "alternateName": "nl"},
          {"@type": "Language", "name": "English", "alternateName": "en"}
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Brussels",
          "addressRegion": "Brussels-Capital",
          "addressCountry": "BE"
        },
        "sameAs": [
          "https://www.linkedin.com/in/cemtekelli/",
          "https://www.linkedin.com/company/codelli-engineering/"
        ]
      },
      {
        "@type": "WebPage",
        "@id": "https://codelli.tech/en/cem-tekelli#webpage",
        "url": "https://codelli.tech/en/cem-tekelli",
        "name": "Cem Tekelli — Founder of Codelli | Full-Stack Developer & AI Expert",
        "isPartOf": {"@id": "https://codelli.tech/#website"},
        "about": {"@id": "https://codelli.tech/cem-tekelli#person"},
        "inLanguage": "en",
        "breadcrumb": {
          "@type": "BreadcrumbList",
          "itemListElement": [
            {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://codelli.tech/en/"},
            {"@type": "ListItem", "position": 2, "name": "Cem Tekelli", "item": "https://codelli.tech/en/cem-tekelli"}
          ]
        }
      }
    ]
  }
  </script>

  <div class="ct-page">

    <!-- Hero -->
    <section class="ct-hero">
      <p class="ct-hero-overline fade-in visible">{t(lang, 'person.hero.overline')}</p>
      <h1 class="ct-hero-name fade-in visible fade-in-delay-1">Cem Tekelli</h1>
      <div class="ct-hero-meta-bar fade-in visible fade-in-delay-2">
        <span class="ct-meta-item">
          <span class="ct-meta-dot"></span>
          <span>{t(lang, 'person.hero.location')}</span>
        </span>
        <span class="ct-meta-item">{t(lang, 'person.hero.speciality')}</span>
        <span class="ct-meta-item">{t(lang, 'person.hero.experience')}</span>
        <span class="ct-meta-item">{t(lang, 'person.hero.availability')}</span>
      </div>
    </section>

    <!-- À propos -->
    <section class="ct-section fade-in" aria-labelledby="ct-bio-label">
      <p class="ct-section-label" id="ct-bio-label">{t(lang, 'person.bio.label')}</p>
      <p class="ct-manifesto fade-in">{t(lang, 'person.bio.manifesto')}</p>
      <div class="ct-bio-grid fade-in">
        <div class="ct-bio-text">
          <p>{t(lang, 'person.bio.p1')}</p>
          <p>{t(lang, 'person.bio.p2')}</p>
          <p>{t(lang, 'person.bio.p3')}</p>
          <p>{t(lang, 'person.bio.p4')}</p>
        </div>
        <div class="ct-avatar-wrap">
          <div class="ct-avatar">
            <div class="ct-avatar-placeholder" aria-label="Photo of Cem Tekelli">
              <span class="ct-avatar-initials">CT</span>
              <span class="ct-avatar-hint">Photo coming soon</span>
            </div>
          </div>
          <div class="ct-avatar-meta">
            <div class="ct-avatar-meta-row">
              <span class="ct-avatar-meta-key">Role</span>
              <span class="ct-avatar-meta-val">Founder & Lead Dev</span>
            </div>
            <div class="ct-avatar-meta-row">
              <span class="ct-avatar-meta-key">Studio</span>
              <span class="ct-avatar-meta-val">Codelli</span>
            </div>
            <div class="ct-avatar-meta-row">
              <span class="ct-avatar-meta-key">Email</span>
              <span class="ct-avatar-meta-val">
                <a href="mailto:tekelli.cem@outlook.com" style="color:inherit;">tekelli.cem@outlook.com</a>
              </span>
            </div>
            <div class="ct-avatar-meta-row">
              <span class="ct-avatar-meta-key">LinkedIn</span>
              <span class="ct-avatar-meta-val">
                <a href="https://www.linkedin.com/in/cemtekelli/" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.5);">linkedin.com/in/cemtekelli →</a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Expertise technique -->
    <section class="ct-section fade-in" aria-labelledby="ct-expertise-label">
      <p class="ct-section-label" id="ct-expertise-label">{t(lang, 'person.expertise.label')}</p>
      <div class="ct-expertise-stack">
        <div class="ct-expertise-row">
          <span class="ct-expertise-cat">{t(lang, 'person.expertise.frontend')}</span>
          <div class="ct-expertise-tags">
            <span class="ct-expertise-tag">React</span>
            <span class="ct-expertise-tag">Vue.js</span>
            <span class="ct-expertise-tag">Next.js</span>
            <span class="ct-expertise-tag">TypeScript</span>
            <span class="ct-expertise-tag">Tailwind</span>
          </div>
        </div>
        <div class="ct-expertise-row">
          <span class="ct-expertise-cat">{t(lang, 'person.expertise.backend')}</span>
          <div class="ct-expertise-tags">
            <span class="ct-expertise-tag">FastAPI</span>
            <span class="ct-expertise-tag">Node.js</span>
            <span class="ct-expertise-tag">Python</span>
            <span class="ct-expertise-tag">GraphQL</span>
            <span class="ct-expertise-tag">REST</span>
          </div>
        </div>
        <div class="ct-expertise-row">
          <span class="ct-expertise-cat">{t(lang, 'person.expertise.ai')}</span>
          <div class="ct-expertise-tags">
            <span class="ct-expertise-tag">n8n</span>
            <span class="ct-expertise-tag">OpenAI API</span>
            <span class="ct-expertise-tag">Anthropic</span>
            <span class="ct-expertise-tag">LLM Integration</span>
            <span class="ct-expertise-tag">RAG</span>
          </div>
        </div>
        <div class="ct-expertise-row">
          <span class="ct-expertise-cat">{t(lang, 'person.expertise.database')}</span>
          <div class="ct-expertise-tags">
            <span class="ct-expertise-tag">PostgreSQL</span>
            <span class="ct-expertise-tag">MongoDB</span>
            <span class="ct-expertise-tag">Redis</span>
            <span class="ct-expertise-tag">Supabase</span>
          </div>
        </div>
        <div class="ct-expertise-row">
          <span class="ct-expertise-cat">{t(lang, 'person.expertise.cloud')}</span>
          <div class="ct-expertise-tags">
            <span class="ct-expertise-tag">AWS</span>
            <span class="ct-expertise-tag">Vercel</span>
            <span class="ct-expertise-tag">Docker</span>
            <span class="ct-expertise-tag">Azure</span>
            <span class="ct-expertise-tag">CI/CD</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Parcours enterprise -->
    <section class="ct-section fade-in" aria-labelledby="ct-exp-label">
      <p class="ct-section-label" id="ct-exp-label">{t(lang, 'person.experience.label')}</p>
      <p class="ct-exp-intro fade-in">{t(lang, 'person.experience.intro')}</p>

      <div class="ct-exp-rows">
        <div class="ct-exp-row">
          <span class="ct-exp-num">01</span>
          <span class="ct-exp-company">IBM</span>
          <span class="ct-exp-desc">{t(lang, 'person.experience.ibmDesc')}</span>
        </div>
        <div class="ct-exp-row">
          <span class="ct-exp-num">02</span>
          <span class="ct-exp-company">DXC Technology</span>
          <span class="ct-exp-desc">{t(lang, 'person.experience.dxcDesc')}</span>
        </div>
        <div class="ct-exp-row">
          <span class="ct-exp-num">03</span>
          <span class="ct-exp-company">RTBF</span>
          <span class="ct-exp-desc">{t(lang, 'person.experience.rtbfDesc')}</span>
        </div>
      </div>

      <div class="ct-exp-bottom">
        <div>
          <p class="ct-exp-col-label">{t(lang, 'person.experience.sectorsLabel')}</p>
          <div class="ct-tag-group">
            <span class="ct-tag">Insurance</span>
            <span class="ct-tag">Laboratories</span>
            <span class="ct-tag">Energy</span>
            <span class="ct-tag">Media</span>
            <span class="ct-tag">Financial services</span>
          </div>
        </div>
        <div>
          <p class="ct-exp-col-label">{t(lang, 'person.experience.typesLabel')}</p>
          <div class="ct-tag-group">
            <span class="ct-tag">Application modernisation</span>
            <span class="ct-tag">From-scratch development</span>
            <span class="ct-tag">Systems integration</span>
            <span class="ct-tag">Digital transformation</span>
            <span class="ct-tag">Cloud architecture</span>
            <span class="ct-tag">APIs &amp; microservices</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="ct-cta-block fade-in">
      <p class="ct-cta-label">{t(lang, 'person.cta.label')}</p>
      <h2 class="ct-cta-title">{t(lang, 'person.cta.title')}</h2>
      <p class="ct-cta-desc">{t(lang, 'person.cta.desc')}</p>
      <a href={CALENDLY_URL} target="_blank" rel="noopener" class="ct-cta-btn" onclick="trackCalendlyClick('cem_tekelli_cta')">
        <span>{t(lang, 'person.cta.btn')}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Fade-in on scroll for non-hero elements -->
  <script is:inline>
    (function() {
      var els = document.querySelectorAll('.ct-page .fade-in:not(.visible)');
      if (!els.length) return;
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });
      els.forEach(function(el) { observer.observe(el); });
    })();
  </script>
</PageLayout>

<style is:global>
  /* ─── Cem Tekelli page ───────────────────────────────────────── */

  /* Fade-in utility for this page */
  .ct-page .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.75s cubic-bezier(0.16,1,0.3,1), transform 0.75s cubic-bezier(0.16,1,0.3,1);
  }
  .ct-page .fade-in.visible { opacity: 1; transform: translateY(0); }
  .fade-in-delay-1 { transition-delay: 0.1s; }
  .fade-in-delay-2 { transition-delay: 0.2s; }

  @media (prefers-reduced-motion: reduce) {
    .ct-page .fade-in { opacity: 1; transform: none; transition: none; }
  }

  /* Back button */
  /* Hero */
  .ct-hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 5rem 3rem 4rem;
  }

  .ct-hero-overline {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 2.5rem;
  }

  .ct-hero-name {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 11vw, 9rem);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.05em;
    color: var(--color-text);
    margin-bottom: 5rem;
  }

  .ct-hero-meta-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 1.5rem;
  }

  .ct-meta-item {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.04em;
    padding-right: 1.75rem;
    margin-right: 1.75rem;
    border-right: 1px solid rgba(255,255,255,0.06);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ct-meta-item:last-child { border-right: none; padding-right: 0; margin-right: 0; }

  .ct-meta-dot {
    display: inline-block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* Section wrapper */
  .ct-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 5.25rem 3rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ct-section-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 3rem;
  }

  /* Manifesto + bio */
  .ct-manifesto {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.6rem);
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    line-height: 1.4;
    letter-spacing: -0.025em;
    max-width: 900px;
    margin-bottom: 4rem;
  }

  .ct-bio-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 5rem;
    align-items: start;
  }

  .ct-bio-text p {
    font-size: 0.98rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .ct-bio-text p:last-child { margin-bottom: 0; }

  /* Avatar */
  .ct-avatar-wrap {
    position: sticky;
    top: 6rem;
  }

  .ct-avatar {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ct-avatar-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .ct-avatar-initials {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255,255,255,0.08);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ct-avatar-hint {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.05em;
  }

  .ct-avatar-meta {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ct-avatar-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .ct-avatar-meta-row:first-child { border-top: 1px solid rgba(255,255,255,0.06); }

  .ct-avatar-meta-key {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ct-avatar-meta-val {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.7);
  }

  /* Expertise */
  .ct-expertise-stack {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ct-expertise-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    cursor: default;
    transition: padding-left 0.5s cubic-bezier(0.16,1,0.3,1);
    position: relative;
    overflow: hidden;
  }

  .ct-expertise-row::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  .ct-expertise-row:hover::before { transform: scaleY(1); }
  .ct-expertise-row:hover { padding-left: 1.5rem; }

  .ct-expertise-cat {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 500;
    line-height: 0.9;
    color: rgba(255,255,255,0.08);
    letter-spacing: -0.05em;
