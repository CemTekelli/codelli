---
import { type Lang, t } from '../../i18n/utils';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="services-section" id="services">
  <div class="services-container">
    <header class="services-header">
      <h2 class="services-title">{t(lang, 'services.title')}</h2>
      <p class="services-intro">{t(lang, 'services.intro')}</p>
    </header>

    <div class="services-stack">
      <!-- Service 1 — Site web -->
      <article class="service-block">
        <div class="service-block-left">
          <h3 class="service-title">{t(lang, 'services.showcase.title')}</h3>
        </div>
        <div class="service-block-right">
          <span class="service-tagline">{t(lang, 'services.showcase.tagline')}</span>
          <p class="service-desc">{t(lang, 'services.showcase.desc')}</p>
          <span class="service-price">{t(lang, 'services.showcase.price')}</span>
        </div>
      </article>

      <!-- Service 2 — IA & Automatisation (featured) -->
      <article class="service-block service-block--featured">
        <div class="service-block-left">
          <h3 class="service-title">{t(lang, 'services.ai.title')}</h3>
        </div>
        <div class="service-block-right">
          <span class="service-tagline">{t(lang, 'services.ai.tagline')}</span>
          <p class="service-desc">{t(lang, 'services.ai.desc')}</p>
          <span class="service-price">{t(lang, 'services.ai.price')}</span>
        </div>
      </article>

      <!-- Service 3 — Applications & SaaS -->
      <article class="service-block">
        <div class="service-block-left">
          <h3 class="service-title">{t(lang, 'services.web.title')}</h3>
        </div>
        <div class="service-block-right">
          <span class="service-tagline">{t(lang, 'services.web.tagline')}</span>
          <p class="service-desc">{t(lang, 'services.web.desc')}</p>
          <span class="service-price">{t(lang, 'services.web.price')}</span>
        </div>
      </article>
    </div>
  </div>
</section>
