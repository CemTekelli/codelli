---
import { type Lang, t } from '../../i18n/utils';
import { CALENDLY_URL } from '../../config';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="contact-section" id="contact">
  <div class="contact-container">
    <header class="contact-header">
      <h2 class="contact-title">{t(lang, 'contact.title')}</h2>
    </header>

    <!-- Calendly Primary CTA -->
    <div class="contact-calendly-cta">
      <p class="calendly-cta-label">{t(lang, 'contact.calendlyLabel')}</p>
      <h3 class="calendly-cta-title">{t(lang, 'contact.calendlyTitle')}</h3>
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener"
        class="contact-book-btn"
        onclick="trackCalendlyClick('contact_section')"
      >
        {t(lang, 'ui.bookCall')}
      </a>
    </div>

    <!-- Contact Content -->
    <div class="contact-content">
      <!-- Left: Quick Info -->
      <div class="contact-info">
        <a href="mailto:hello@codelli.tech" class="contact-email">hello@codelli.tech</a>
        <div class="contact-meta">
          <span>{t(lang, 'hero.location')}</span>
          <span>·</span>
          <span>+32 472 62 84 30</span>
        </div>
        <div class="contact-social">
          <a
            href="https://www.linkedin.com/company/codelli-engineering/"
            target="_blank"
            rel="noopener"
            aria-label={t(lang, 'social.linkedin')}
          >Li</a>
          <a
            href="https://www.instagram.com/codelli.tech/"
            target="_blank"
            rel="noopener"
            aria-label={t(lang, 'social.instagram')}
          >Ig</a>
        </div>
      </div>

      <!-- Right: Contact Form (Netlify) -->
      <form
        class="contact-form"
        id="contactForm"
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p style="display:none">
          <label>Ne pas remplir: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <div class="form-field">
            <input
              type="text"
              id="name"
              name="name"
              class="field-input"
              placeholder={t(lang, 'contact.form.name')}
              required
            />
          </div>
          <div class="form-field">
            <input
              type="email"
              id="email"
              name="email"
              class="field-input"
              placeholder={t(lang, 'contact.form.email')}
              required
            />
          </div>
        </div>

        <div class="form-field">
          <input
            type="text"
            id="company"
            name="company"
            class="field-input"
            placeholder={t(lang, 'contact.form.company')}
          />
        </div>

        <div class="form-field">
          <textarea
            id="message"
            name="message"
            class="field-textarea"
            placeholder={t(lang, 'contact.form.message')}
            rows="3"
            required
          ></textarea>
        </div>

        <button type="submit" class="form-submit-btn">
          <span>{t(lang, 'contact.form.submit')}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>
