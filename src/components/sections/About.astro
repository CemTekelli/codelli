---
import { type Lang, t, localePath } from '../../i18n/utils';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="about-section" id="about">
  <div class="about-container">
    <header class="about-header">
      <h2 class="about-title">{t(lang, 'about.title')}</h2>
    </header>

    <blockquote class="about-manifesto">
      <p class="manifesto-text">
        <a href={localePath(lang, '/cem-tekelli')} class="about-founder-link">Cem Tekelli</a>
        {' '}{t(lang, 'about.lead')}
      </p>
      <div class="about-founder-links">
        <a href={localePath(lang, '/cem-tekelli')} class="about-founder-cta">
          {t(lang, 'about.founderProfile')}
        </a>
        <a href={localePath(lang, '/blog/')} class="about-founder-cta">
          {t(lang, 'about.allArticles')}
        </a>
      </div>
    </blockquote>

    <div class="about-values-list">
      <div class="about-value-row">
        <span class="value-number">01</span>
        <h3 class="value-title">{t(lang, 'about.values.roof.title')}</h3>
        <p class="value-desc">{t(lang, 'about.values.roof.desc')}</p>
      </div>
      <div class="about-value-row">
        <span class="value-number">02</span>
        <h3 class="value-title">{t(lang, 'about.values.ai.title')}</h3>
        <p class="value-desc">{t(lang, 'about.values.ai.desc')}</p>
      </div>
      <div class="about-value-row">
        <span class="value-number">03</span>
        <h3 class="value-title">{t(lang, 'about.values.price.title')}</h3>
        <p class="value-desc">{t(lang, 'about.values.price.desc')}</p>
      </div>
      <div class="about-value-row">
        <span class="value-number">04</span>
        <h3 class="value-title">{t(lang, 'about.values.local.title')}</h3>
        <p class="value-desc">{t(lang, 'about.values.local.desc')}</p>
      </div>
    </div>
  </div>
</section>
