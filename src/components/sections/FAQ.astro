---
import { type Lang, t } from '../../i18n/utils';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const faqs = ['1', '2', '3', '4', '5', '6'] as const;
---

<section class="faq-section" id="faq" aria-label={t(lang, 'faq.title')}>
  <div class="faq-container">
    <header class="faq-header">
      <h2 class="faq-title">{t(lang, 'faq.title')}</h2>
    </header>
    <div class="faq-list">
      {faqs.map((n) => (
        <details class="faq-item">
          <summary class="faq-question">{t(lang, `faq.q${n}`)}</summary>
          <p class="faq-answer">{t(lang, `faq.a${n}`)}</p>
        </details>
      ))}
    </div>
  </div>
</section>
