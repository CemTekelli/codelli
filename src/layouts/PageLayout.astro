---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import StickyMobileCta from '../components/StickyMobileCta.astro';
import { type Lang, getLangFromUrl } from '../i18n/utils';

export interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
  hreflangUrls?: Partial<Record<Lang, string>>;
  /** Override lang switcher URLs in the nav (for sub-pages with translated slugs). */
  navLangUrls?: { fr?: string; en?: string; nl?: string };
  /** If set, shows a back button in the nav bar. */
  navBackHref?: string;
  /** Label for the back button. */
  navBackLabel?: string;
}

const {
  lang = getLangFromUrl(Astro.url),
  title,
  description,
  canonical,
  ogImage,
  bodyClass = 'loading',
  hreflangUrls,
  navLangUrls,
  navBackHref,
  navBackLabel,
} = Astro.props;
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  bodyClass={bodyClass}
  hreflangUrls={hreflangUrls}
>
  <slot name="schema" slot="schema" />
  <slot name="head" slot="head" />

  <Nav
    lang={lang}
    langUrls={navLangUrls}
    backHref={navBackHref}
    backLabel={navBackLabel}
  />

  <main>
    <slot />
  </main>

  <Footer lang={lang} />
  <CookieBanner lang={lang} />
  <StickyMobileCta lang={lang} />
</BaseLayout>
