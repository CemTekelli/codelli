---
/**
 * Layout pour les articles de blog
 * Reprend le design de blog.css — même langue de design que le site principal
 */
import PageLayout from './PageLayout.astro';
import { type Lang, t, localePath, getLangFromUrl } from '../i18n/utils';

export interface Props {
  lang?: Lang;
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  category: string;
  readingTime: string;
  pubDate: Date;
  author?: string;
  authorRole?: string;
  /** Intro (lead) du hero article */
  intro: string;
  /** Slugs de traduction */
  translationSlugs?: { fr?: string; en?: string; nl?: string };
}

const {
  lang = getLangFromUrl(Astro.url),
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  category,
  readingTime,
  pubDate,
  author = 'Cem Tekelli',
  authorRole = 'Fondateur de Codelli',
  intro,
  translationSlugs,
} = Astro.props;

const dateFormatted = new Intl.DateTimeFormat(
  lang === 'fr' ? 'fr-BE' : lang === 'nl' ? 'nl-BE' : 'en-GB',
  { day: 'numeric', month: 'long', year: 'numeric' }
).format(pubDate);

const dateIso = pubDate.toISOString().split('T')[0];

// hreflang overrides for article pages — slugs differ per lang
const enSlug = translationSlugs?.en;
const nlSlug = translationSlugs?.nl;
const frSlug = translationSlugs?.fr;

// Build per-lang canonical paths
const hreflangUrls: Partial<Record<import('../i18n/utils').Lang, string>> = {};
if (lang === 'fr') hreflangUrls.fr = canonical;
else if (frSlug) hreflangUrls.fr = `/blog/${frSlug}`;

if (lang === 'en') hreflangUrls.en = canonical;
else if (enSlug) hreflangUrls.en = `/en/blog/${enSlug}`;

if (lang === 'nl') hreflangUrls.nl = canonical;
else if (nlSlug) hreflangUrls.nl = `/nl/blog/${nlSlug}`;
---

<PageLayout
  lang={lang}
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  bodyClass=""
  hreflangUrls={hreflangUrls}
  navLangUrls={{
    fr: lang === 'fr' ? canonical : (frSlug ? `/blog/${frSlug}` : '/blog/'),
    nl: nlSlug ? `/nl/blog/${nlSlug}` : '/nl/blog/',
    en: enSlug ? `/en/blog/${enSlug}` : '/en/blog/',
  }}
  navBackHref={localePath(lang, '/blog/')}
  navBackLabel={t(lang, 'blog.nav.backBlog') || 'Blog'}
>
  <slot name="schema" slot="schema" />
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": lang === 'en' ? 'Home' : lang === 'nl' ? 'Startpagina' : 'Accueil',
        "item": `https://codelli.tech${localePath(lang, '/')}`
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": `https://codelli.tech${localePath(lang, '/blog/')}`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": `https://codelli.tech${canonical}`
      }
    ]
  })} />
  <meta property="og:type" content="article" slot="head" />

  <!-- Reading progress bar -->
  <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>

  <div class="blog-page">
    <!-- Article hero -->
    <header class="article-hero fade-in">
      <div class="article-hero-inner">
        <div class="article-hero-top">
          <span class="article-category">{category}</span>
          <span class="article-hero-sep">·</span>
          <span class="article-reading-time">{readingTime}</span>
          <span class="article-hero-sep">·</span>
          <span class="article-reading-time">{t(lang, 'blog.nav.updated')} {dateFormatted}</span>
        </div>
        <h1 class="article-title" itemprop="headline">{title}</h1>
        <p class="article-intro" itemprop="description" set:html={intro} />
        <div class="article-hero-bottom">
          <div class="article-author">
            <div class="author-avatar" aria-hidden="true">CT</div>
            <div class="author-info">
              <a href={localePath(lang, '/cem-tekelli')} class="author-name" itemprop="author">
                {author}
              </a>
              <span class="author-role">{authorRole}</span>
            </div>
          </div>
          <time class="article-date" datetime={dateIso} itemprop="datePublished">{dateFormatted}</time>
        </div>
      </div>
    </header>

    <!-- Article content -->
    <div class="article-wrap">
      <article itemscope itemtype="https://schema.org/BlogPosting">
        <slot />
      </article>
    </div>

  </div>

  <!-- Reading progress script -->
  <script is:inline>
    (function() {
      var bar = document.getElementById('readingProgress');
      if (!bar) return;
      window.addEventListener('scroll', function() {
        var doc = document.documentElement;
        var scrollTop = doc.scrollTop || document.body.scrollTop;
        var scrollHeight = doc.scrollHeight - doc.clientHeight;
        var pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        bar.style.width = pct + '%';
      }, { passive: true });
    })();

    // Fade-in on scroll
    (function() {
      var els = document.querySelectorAll('.blog-page .fade-in:not(.visible)');
      if (!els.length) return;
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
        });
      }, { threshold: 0.06 });
      els.forEach(function(el) { observer.observe(el); });
    })();
  </script>
</PageLayout>

<style is:global>
  /* ─── Blog article layout ─────────────────────────────────── */

  /* Alias legacy CSS vars from blog.css source → Astro design tokens */
  .blog-page {
    --text:      var(--color-text);
    --accent:    var(--color-accent);
    --accent-dim: rgba(255,107,53,0.12);
    --muted:     rgba(255,255,255,0.35);
    --surface:   rgba(255,255,255,0.03);
    --border:    rgba(255,255,255,0.06);
    --font-body: var(--font-sans);
  }

  /* Reading progress */
  .reading-progress {
    position: fixed; top: 0; left: 0;
    height: 2px; background: var(--color-accent);
    z-index: 200; width: 0%;
    box-shadow: 0 0 8px rgba(255,107,53,0.5);
  }

  .blog-page { position: relative; z-index: 2; }

  /* Fade-in */
  .blog-page .fade-in {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .blog-page .fade-in.visible { opacity: 1; transform: translateY(0); }
  .blog-page .delay-2 { transition-delay: 0.2s; }

  @media (prefers-reduced-motion: reduce) {
    .blog-page .fade-in { opacity: 1; transform: none; transition: none; }
    .reading-progress { transition: none; }
  }

  /* Article hero */
  .article-hero {
    position: relative; z-index: 2;
    padding: 4rem 3rem 4.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .article-hero-inner { max-width: 900px; margin: 0 auto; }

  .article-hero-top {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .article-category {
    font-family: var(--font-display);
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-accent);
  }
  .article-hero-sep { color: rgba(255,255,255,0.15); font-size: 0.78rem; }
  .article-reading-time {
    font-family: var(--font-sans);
    font-size: 0.72rem; color: rgba(255,255,255,0.35);
    letter-spacing: 0.04em;
  }
  h1.article-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    font-weight: 500; line-height: 1.05;
    letter-spacing: -0.045em; color: var(--color-text);
    margin-bottom: 2rem;
  }
  .article-intro {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: rgba(255,255,255,0.5); line-height: 1.75;
    margin-bottom: 3rem; max-width: 680px;
  }
  .article-intro strong { color: rgba(255,255,255,0.75); }
  .article-hero-bottom {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 1.5rem; flex-wrap: wrap; gap: 1rem;
  }
  .article-author { display: flex; align-items: center; gap: 0.75rem; }
  .author-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,107,53,0.12);
    border: 1px solid rgba(255,107,53,0.3);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 600; font-size: 0.8rem;
    color: var(--color-accent); flex-shrink: 0;
  }
  .author-name {
    display: block; font-family: var(--font-display);
    font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.8);
    text-decoration: none;
  }
  .author-name:hover { color: rgba(255,255,255,1); }
  .author-role { display: block; font-size: 0.75rem; color: rgba(255,255,255,0.3); }
  .article-date { font-family: var(--font-sans); font-size: 0.82rem; color: rgba(255,255,255,0.3); }

  /* Article wrap + body */
  .article-wrap { max-width: 900px; margin: 0 auto; padding: 4rem 3rem 6rem; }

  .article-wrap .toc {
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem 1.75rem;
    margin-bottom: 3rem;
    background: rgba(255,255,255,0.02);
  }
  .article-wrap .toc-title {
    font-family: var(--font-display); font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 1rem;
  }
  .article-wrap .toc ol {
    padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.45rem;
  }
  .article-wrap .toc li { font-size: 0.88rem; }
  .article-wrap .toc a {
    color: rgba(255,255,255,0.5); text-decoration: none;
    transition: color 0.2s;
  }
  .article-wrap .toc a:hover { color: rgba(255,255,255,0.9); }

  /* Article body typography */
  .article-body { display: flex; flex-direction: column; }
  .article-body section { margin-bottom: 3.5rem; }
  .article-body h2 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.65rem);
    font-weight: 500; letter-spacing: -0.025em;
    color: var(--color-text); line-height: 1.25;
    margin-bottom: 1.5rem; padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: baseline; gap: 1rem;
  }
  .article-body h2::before {
    content: counter(h2-counter);
    counter-increment: h2-counter;
    font-family: var(--font-display); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.1em; color: var(--color-accent); opacity: 0.5;
    min-width: 1.8rem; flex-shrink: 0;
  }
  .article-body { counter-reset: h2-counter; }
  .article-body section:first-child h2 { border-top: none; padding-top: 0; }
  .article-body h3 {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 500; letter-spacing: -0.02em;
    color: rgba(255,255,255,0.85); margin-top: 2rem; margin-bottom: 0.75rem;
  }
  .article-body p {
    font-family: var(--font-sans); font-size: 0.97rem;
    color: rgba(255,255,255,0.6); line-height: 1.85; margin-bottom: 1.25rem;
  }
  .article-body p:last-child { margin-bottom: 0; }
  .article-body strong { color: rgba(255,255,255,0.85); font-weight: 600; }
  .article-body em { color: rgba(255,255,255,0.75); font-style: italic; }
  .article-body a { color: var(--color-accent); text-decoration: underline; text-decoration-color: rgba(255,107,53,0.4); }
  .article-body a:hover { text-decoration-color: var(--color-accent); }
  .article-body ul, .article-body ol {
    padding-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem;
  }
  .article-body li {
    font-family: var(--font-sans); font-size: 0.95rem;
    color: rgba(255,255,255,0.6); line-height: 1.7;
  }
  .article-body code {
    font-family: 'Courier New', monospace; font-size: 0.85em;
    background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.8);
    padding: 0.15em 0.4em; border-radius: 3px;
  }

  /* Boxes */
  .highlight-box {
    border-left: 2px solid var(--color-accent);
    padding: 1.25rem 1.5rem;
    background: rgba(255,107,53,0.05);
    margin: 1.5rem 0;
  }
  .highlight-box p { margin-bottom: 0; font-size: 0.93rem; }
  .info-box {
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.02);
    margin: 1.5rem 0;
  }
  .info-box p { margin-bottom: 0.5rem; }
  .info-box p:last-child { margin-bottom: 0; }

  /* Tables */
  .table-wrapper {
    overflow-x: auto; -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
  }
  .article-body table {
    width: 100%; min-width: 520px; border-collapse: collapse;
    font-family: var(--font-sans);
  }
  .article-body th {
    text-align: left; padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.5); font-family: var(--font-display);
    font-weight: 500; font-size: 0.72rem;
    letter-spacing: 0.08em; text-transform: uppercase; white-space: nowrap;
    background: rgba(255,255,255,0.02);
  }
  .article-body td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.55); font-size: 0.88rem; vertical-align: top;
  }
  .article-body tr:last-child td { border-bottom: none; }
  .article-body td strong { color: rgba(255,255,255,0.8); }
  .article-body td code {
    font-size: 0.82rem; background: rgba(255,255,255,0.06);
    padding: 0.1rem 0.35rem; border-radius: 3px;
  }

  /* Badge cells in tables */
  .badge-yes { color: #4ade80; font-size: 0.82rem; }
  .badge-partial { color: #facc15; font-size: 0.82rem; }
  .badge-no { color: rgba(255,255,255,0.25); font-size: 0.82rem; }

  /* LLM cards grid */
  .llm-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
    margin: 1.5rem 0;
  }
  .llm-card {
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.25rem; background: rgba(255,255,255,0.02);
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .llm-badge {
    display: inline-block; font-family: var(--font-display);
    font-size: 0.62rem; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.2rem 0.6rem;
    border-radius: 100px; margin-bottom: 0.25rem; align-self: flex-start;
  }
  .badge-best { background: rgba(255,107,53,0.15); color: var(--color-accent); border: 1px solid rgba(255,107,53,0.25); }
  .badge-eu { background: rgba(74,222,128,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .badge-budget { background: rgba(250,204,21,0.1); color: #facc15; border: 1px solid rgba(250,204,21,0.2); }
  .llm-name { font-family: var(--font-display); font-size: 1rem; font-weight: 500; color: var(--color-text); }
  .llm-maker { font-size: 0.78rem; color: rgba(255,255,255,0.35); }
  .llm-price { font-family: var(--font-display); font-size: 0.82rem; color: var(--color-accent); }
  .llm-use { font-size: 0.82rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

  /* Architecture flow */
  .arch-flow {
    display: flex; flex-direction: column; gap: 0;
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem; background: rgba(255,255,255,0.02);
    margin: 1.5rem 0;
  }
  .arch-step {
    display: flex; align-items: flex-start; gap: 1rem; padding: 0.75rem 0;
  }
  .arch-arrow { text-align: center; color: rgba(255,255,255,0.2); padding: 0.25rem 0; font-size: 1.2rem; }
  .arch-icon { font-size: 1.5rem; flex-shrink: 0; width: 2rem; text-align: center; }
  .arch-label { font-family: var(--font-display); font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.8); }
  .arch-desc { font-size: 0.82rem; color: rgba(255,255,255,0.4); line-height: 1.5; margin-top: 0.2rem; }

  /* Comparison grid (verdicts) */
  .verdict-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0; }
  .verdict-col {
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.25rem; background: rgba(255,255,255,0.02);
  }
  .verdict-col.highlighted { border-color: rgba(255,107,53,0.3); background: rgba(255,107,53,0.04); }
  .verdict-title {
    font-family: var(--font-display); font-size: 0.88rem; font-weight: 500;
    color: rgba(255,255,255,0.8); margin-bottom: 0.75rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .verdict-title .v-badge {
    font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.15rem 0.5rem; border-radius: 100px;
    background: rgba(255,107,53,0.15); color: var(--color-accent);
  }
  .verdict-col ul { margin-bottom: 0; }
  .verdict-col li { font-size: 0.83rem; }

  /* Checklist */
  .checklist { list-style: none; padding: 0; margin: 1.25rem 0; }
  .checklist li {
    display: flex; gap: 0.85rem; align-items: flex-start;
    padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 0.9rem; color: rgba(255,255,255,0.7);
  }
  .checklist li:last-child { border-bottom: none; }
  .checklist li::before { content: '✓'; color: #4ade80; font-weight: 700; flex-shrink: 0; margin-top: 0.05rem; }
  .checklist li.warn::before { content: '⚠'; color: #f97316; }

  /* Steps list (numbered circles) */
  .steps-list { list-style: none; padding: 0; margin: 1.5rem 0; counter-reset: steps; }
  .steps-list li { counter-increment: steps; display: flex; gap: 1.25rem; margin-bottom: 1.5rem; align-items: flex-start; }
  .steps-list li::before {
    content: counter(steps);
    flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,107,53,0.12); border: 1px solid rgba(255,107,53,0.3);
    color: var(--color-accent); font-family: var(--font-display); font-weight: 500; font-size: 0.85rem;
    display: flex; align-items: center; justify-content: center;
  }
  .step-content strong { display: block; color: var(--color-text); margin-bottom: 0.3rem; font-family: var(--font-display); font-weight: 500; }
  .step-content { color: rgba(255,255,255,0.65); font-size: 0.9rem; line-height: 1.7; }

  /* Subsidy grid */
  .subsidy-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .subsidy-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; padding: 1.25rem; }
  .subsidy-card .region { font-family: var(--font-display); font-size: 0.68rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.5rem; }
  .subsidy-card .program { font-family: var(--font-display); font-weight: 500; color: var(--color-text); margin-bottom: 0.35rem; font-size: 0.92rem; }
  .subsidy-card .amount { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: #4ade80; margin-bottom: 0.35rem; }
  .subsidy-card .detail { font-size: 0.78rem; color: rgba(255,255,255,0.35); line-height: 1.5; }
  .subsidy-card .warning { font-size: 0.75rem; color: #f97316; margin-top: 0.4rem; line-height: 1.4; }

  /* LLM comparison cards — overrides for article-specific badge colors */
  .llm-card .llm-name { font-family: var(--font-display); font-weight: 600; color: var(--color-text); margin-bottom: 0.25rem; font-size: 0.95rem; }
  .llm-card .llm-maker { font-size: 0.72rem; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
  .llm-card .llm-price { font-family: var(--font-display); font-size: 0.85rem; color: #4ade80; margin-bottom: 0.5rem; }
  .llm-card .llm-use { font-size: 0.8rem; color: rgba(255,255,255,0.35); line-height: 1.5; }
  .llm-card .llm-badge { display: inline-block; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 3px; margin-bottom: 0.6rem; }
  .badge-eu { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.25); }
  .badge-best { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .badge-budget { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }

  /* Benchmark bars (fastapi article) */
  .bench-list { list-style: none; padding: 0; margin: 1.5rem 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .bench-item { display: flex; align-items: center; gap: 1rem; }
  .bench-label { font-family: var(--font-display); font-size: 0.82rem; font-weight: 500; color: var(--color-text); min-width: 120px; flex-shrink: 0; }
